@model ORM1.Models.Room_BCS240051

<h2>Xóa phòng</h2>

<h4>Bạn có chắc muốn xóa?</h4>

<table class="table">

    <tr>
        <th>ID</th>
        <td>@Model.Id</td>
    </tr>

    <tr>
        <th>Tên phòng</th>
        <td>@Model.Name</td>
    </tr>

</table>

<form asp-action="Delete">

    <input type="hidden"
           asp-for="Id" />

    <button type="submit"
            class="btn btn-danger">
        Xóa
    </button>

    <a asp-action="Index"
       class="btn btn-secondary">
        Hủy
    </a>

</form>@*
